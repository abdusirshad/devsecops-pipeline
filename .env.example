# Copy to .env and adjust. No real secrets belong in this repo.
# .env is git-ignored.

# Application
APP_VERSION=1.0.0

# Local image coordinates used by the Makefile
IMAGE_NAME=devsecops-sample-api
IMAGE_TAG=local

# Example placeholder (NOT a real credential) — present only to show the
# secrets scanner ignores documented placeholders via .gitleaks.toml.
EXAMPLE_API_TOKEN=your-token-here
